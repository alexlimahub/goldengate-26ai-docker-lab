# Copy this file to vdt.env and fill in your values before running the lab.
#   cp vdt.env.example vdt.env

# Veridata admin username
VDT_ADMINISTRATOR_USER=veridata

# Use the same password you set in .env (YOUR_PASSWORD)
VDT_ADMINISTRATOR_PASSWORD=YOUR_PASSWORD

# JDBC URL for the Veridata agent to connect to the source database
# Uses the internal Docker network IP for dbWEST (matches DOCKER_DB_WEST_IP in .env)
VDT_AGENT_JDBC_DATABASE_URL=jdbc:oracle:thin:@172.52.0.103:1521/freepdb1

# JDBC driver type
VDT_AGENT_JDBCDRIVER=ojdbc11
