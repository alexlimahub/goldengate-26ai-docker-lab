# Copy this file to .env and set YOUR_PASSWORD before running the lab.
#   cp .env.example .env
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  SET ONE PASSWORD FOR ALL SERVICES                                      │
# │                                                                         │
# │  Replace YOUR_PASSWORD below with a single password that will be used   │
# │  for GoldenGate, Oracle Database, and Grafana.                          │
# │                                                                         │
# │  Password requirements (Oracle policy):                                 │
# │    - At least 8 characters                                              │
# │    - At least 1 uppercase letter                                        │
# │    - At least 1 lowercase letter                                        │
# │    - At least 1 number                                                  │
# │    - At least 1 special character  (e.g. #, !, @)                      │
# │                                                                         │
# │  Example:  MyLab##2026                                                  │
# └─────────────────────────────────────────────────────────────────────────┘

# ── GoldenGate Hub ────────────────────────────────────────────────────────────
OGG_ADMIN_PWD=YOUR_PASSWORD
OGG_LISTEN_ON=0.0.0.0

# ── Oracle Database ───────────────────────────────────────────────────────────
ORACLE_PASSWORD=YOUR_PASSWORD

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=YOUR_PASSWORD
GF_INSTALL_PLUGINS=

# ── InfluxDB ──────────────────────────────────────────────────────────────────
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=YOUR_PASSWORD
DOCKER_INFLUXDB_INIT_RETENTION=4d

# ── Replication variables (used by 1_create_replication.sh) ───────────────────
source_host=https://localhost:9090
target_host=https://localhost:8080
username=oggadmin
password=YOUR_PASSWORD
extract_name=EXTW
replicat_name=REPE
trail_prefix=ew
distribution_path_name=DP1

# ── Network IPs (do not change unless you have a subnet conflict) ─────────────
DOCKER_OGG_WEST_IP=172.52.0.101
DOCKER_OGG_EAST_IP=172.52.0.102
DOCKER_DB_WEST_IP=172.52.0.103
DOCKER_DB_EAST_IP=172.52.0.104
DOCKER_VERIDATA_IP=172.52.0.203
DOCKER_TELEGRAF_IP=172.52.0.200
DOCKER_INFLUXDB_IP=172.52.0.201
DOCKER_GRAFANA_IP=172.52.0.202
