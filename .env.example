# Copy this file to .env and fill in your values before running the lab.
#   cp .env.example .env

# ── Network IPs ───────────────────────────────────────────────────────────────
DOCKER_OGG_WEST_IP=172.52.0.101
DOCKER_OGG_EAST_IP=172.52.0.102
DOCKER_DB_WEST_IP=172.52.0.103
DOCKER_DB_EAST_IP=172.52.0.104
DOCKER_VERIDATA_IP=172.52.0.203
DOCKER_TELEGRAF_IP=172.52.0.200
DOCKER_INFLUXDB_IP=172.52.0.201
DOCKER_GRAFANA_IP=172.52.0.202

# ── GoldenGate Hub ────────────────────────────────────────────────────────────
OGG_ADMIN_PWD=<your-password>
OGG_LISTEN_ON=0.0.0.0

# ── Oracle Database ───────────────────────────────────────────────────────────
ORACLE_PASSWORD=<your-password>

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<your-password>
GF_INSTALL_PLUGINS=

# ── InfluxDB ──────────────────────────────────────────────────────────────────
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=<your-password>
DOCKER_INFLUXDB_INIT_RETENTION=4d

# ── Replication test variables (used by 1_create_replication.sh) ──────────────
source_host=https://localhost:9090
target_host=https://localhost:8080
username=oggadmin
password=<your-password>
extract_name=EXTW
replicat_name=REPE
trail_prefix=ew
distribution_path_name=DP1
